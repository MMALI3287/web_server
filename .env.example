# Optional environment variables for enhanced security

# Port to run the server on
PORT=3000

# Host to bind to (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Node environment (development or production)
# In production, debug logs are suppressed
NODE_ENV=development

# Trust proxy (set to true if behind a reverse proxy like nginx)
TRUST_PROXY=false

# Comma-separated list of allowed origins for CORS (leave empty to disable CORS)
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=

# Rate limiting settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
DOWNLOAD_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_MAX=10

# File upload size limit in bytes (default: 100MB)
MAX_FILE_SIZE=104857600

# Authentication credentials (bcrypt-hashed passwords)
# Generate a hash: node -e "require('bcrypt').hash('yourpassword', 10).then(h => console.log(h))"
ADMIN_USER=admin
ADMIN_PASS_HASH=
VIEWER_USER=viewer
VIEWER_PASS_HASH=

# Session secret for cookie signing (auto-generated if not set)
SESSION_SECRET=

# CSRF secret for token signing (auto-generated if not set)
CSRF_SECRET=

# Share link settings
# SHARE_LINK_TTL_MS=86400000
# SHARE_MAX_DOWNLOADS=0
